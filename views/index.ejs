<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Message Board</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <div class="receipt-container">
    <h1>MESSAGE BOARD</h1>

    <div class="sticky-header">
      <div class="header-row">
        <span>ARCHIVE LOG</span>
        <a href="/new" class="action-link">[ + ADD NEW ENTRY ]</a>
      </div>
      <div class="divider">============================================================</div>
    </div>

    <% if (messages && messages.length > 0) { %>
    <% messages.forEach(function(msg) { %>
    <div class="entry">

      <div class="entry-text">
        <%= msg.user %>:
        <a href="/message/<%= msg.id %>" class="invisible-link">
          <%= msg.text %>
        </a>
      </div>

      <div class="divider">------------------------------------------------------------</div>

      <div class="meta-row">
        <button class="like-btn <%= msg.liked ? 'liked' : '' %>" onclick="toggleLike(this, '<%= msg.id %>')">
          <span class="heart"><%= msg.liked ? '♥' : '♡' %></span>
          <span class="like-count">
            <%= msg.likes.toString().padStart(3, '0') %>
          </span>
        </button>

        <span>
          <%= formatDateTime(msg.date) %>
        </span>
      </div>

    </div>
    <% }); %>
    <% } else { %>
    <div class="entry-text">NO ENTRIES FOUND.</div>
    <% } %>
  </div>

  <script>
    async function toggleLike(btn, id) {
      const countSpan = btn.querySelector('.like-count');
      const heartSpan = btn.querySelector('.heart');

      try {
        const res = await fetch(`/like/${id}`, {
          method: "POST",
        });

        const data = await res.json();

        countSpan.innerText = data.likes.toString().padStart(3, '0');

        if (data.liked) {
          btn.classList.add('liked');
          heartSpan.innerText = '♥';
        } else {
          btn.classList.remove('liked');
          heartSpan.innerText = '♡';
        }

      } catch (err) {
        console.error("Like failed:", err);
      }
    }
  </script>
</body>

</html>